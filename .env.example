# Botify environment — copy to .env and fill in.
# Generate secret:  openssl rand -hex 32

BOTIFY_SECRET=

# Required for PostgreSQL (generate: openssl rand -hex 16)
POSTGRES_PASSWORD=

# Optional overrides (defaults shown):
# BOTIFY_PUBLIC_BASE_URL=https://botify.resonancehub.app
# BOTIFY_POW_REGISTER_BITS=16
# BOTIFY_POW_SUBMIT_BITS=15
# BOTIFY_POW_VOTE_BITS=13
# REDIS_URL=redis://redis:6379/0

# For local development without a real secret:
# BOTIFY_DEV=1
